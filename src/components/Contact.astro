<section class="section" id="contact">
  <div class="container">
    <h2 class="section-title">Contacto</h2>
    <p class="contact-text">
      Estoy abierto a oportunidades laborales y colaboraciones. Si tienes un
      proyecto en mente, no dudes en escribirme.
    </p>
    <a href="mailto:contacto@hmoreira.dev" class="contact-email">
      contacto@hmoreira.dev
    </a>
    <div class="contact-social">
      <a href="https://github.com/hmoreirar" target="_blank">GitHub</a>
      <span>/</span>
      <a href="https://linkedin.com/in/hmoreirar" target="_blank">LinkedIn</a>
    </div>
  </div>
</section>

<style>
  .contact-text {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 24px;
    max-width: 480px;
  }

  .contact-email {
    display: inline-block;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
    margin-bottom: 16px;
    transition: color 0.2s ease;
  }

  .contact-email:hover {
    color: var(--accent);
  }

  .contact-social {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .contact-social a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s ease;
  }

  .contact-social a:hover {
    color: var(--accent);
  }

  .contact-social span {
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .contact-email {
      font-size: 1.3rem;
    }
  }
</style>
