---
interface Project {
  title: string;
  description: string;
  tech: string[];
  links: { label: string; url: string }[];
  screenshot?: string;
  icon?: string;
}

const projects: Project[] = [
  {
    title: "Climate Dashboard",
    description:
      "Dashboard IoT en tiempo real con sensores ESP32. Conexión desde el sensor hasta la UI con Next.js, PostgreSQL y Recharts.",
    tech: ["Next.js", "TypeScript", "PostgreSQL", "Tailwind CSS", "Recharts"],
    links: [
      { label: "Demo", url: "https://climate-dashboard-one.vercel.app/" },
      { label: "GitHub", url: "https://github.com/hmoreirar/climate-dashboard" },
    ],
    screenshot: "/projects/climate-dashboard.jpg",
  },
  {
    title: "Reservas SaaS",
    description:
      "Plataforma de reservas tipo Calendly con dashboard de estadísticas, booking público y notificaciones por email.",
    tech: ["React", "Express", "PostgreSQL", "JWT", "Tailwind CSS"],
    links: [
      { label: "Demo", url: "https://reservas-saas-production.up.railway.app/" },
      { label: "GitHub", url: "https://github.com/hmoreirar/reservas-saas" },
    ],
    screenshot: "/projects/reservas-saas.jpg",
  },
  {
    title: "Nicommerce",
    description:
      "E-commerce completo con panel de administración, carrito de compras persistente, checkout multi-paso y Docker.",
    tech: ["React", "Express", "PostgreSQL", "Docker", "Nginx"],
    links: [
      { label: "GitHub", url: "https://github.com/hmoreirar/nicommerce" },
    ],
    icon: "cart",
  },
  {
    title: "Job Tracker",
    description:
      "Gestor de postulaciones laborales con autenticación, CRUD completo y estadísticas del progreso en dashboard.",
    tech: ["Next.js", "TypeScript", "Supabase", "Tailwind CSS"],
    links: [
      { label: "Demo", url: "https://job-tracker-beige-three.vercel.app/" },
      { label: "GitHub", url: "https://github.com/hmoreirar/job-tracker" },
    ],
    screenshot: "/projects/job-tracker.jpg",
  },
  {
    title: "Calendario App",
    description:
      "Calendario con eventos recurrentes (RRULE), recordatorios y autenticación con Row Level Security.",
    tech: ["React", "FullCalendar", "Supabase", "RRULE"],
    links: [
      { label: "GitHub", url: "https://github.com/hmoreirar/calendario-app" },
    ],
    icon: "calendar",
  },
  {
    title: "Climate Monitor (Firmware)",
    description:
      "Firmware para ESP32 y ESP8266 con sensores SHT3X y BME280. Envío de datos a Supabase vía HTTP.",
    tech: ["C++", "PlatformIO", "ESP32", "ESP8266", "HTTP"],
    links: [
      { label: "GitHub", url: "https://github.com/hmoreirar/climate-monitor-system" },
    ],
    icon: "chip",
  },
  {
    title: "Astroblog",
    description:
      "Fanzine digital estático con estética dark y tipografía monospace. Deployado en GitHub Pages.",
    tech: ["Astro", "TypeScript", "Markdown", "GitHub Pages"],
    links: [
      { label: "Demo", url: "https://hmoreirar.github.io/astroblog" },
      { label: "GitHub", url: "https://github.com/hmoreirar/astroblog" },
    ],
    screenshot: "/projects/astroblog.jpg",
  },
  {
    title: "Taller Piduco",
    description:
      "Portfolio para taller de carpintería artesanal con galería de imágenes, servicios y storytelling visual.",
    tech: ["React", "Vite", "CSS"],
    links: [
      { label: "GitHub", url: "https://github.com/hmoreirar/camilo-madeira" },
    ],
    icon: "tool",
  },
  {
    title: "Climapp",
    description:
      "App del clima con datos en tiempo real, pronóstico de 5 días, geolocalización y modo oscuro.",
    tech: ["React", "TypeScript", "OpenWeatherMap API"],
    links: [
      { label: "GitHub", url: "https://github.com/hmoreirar/weather-app" },
    ],
    icon: "sun",
  },
];
---

<section class="section" id="projects">
  <div class="container">
    <h2 class="section-title">Proyectos destacados</h2>
    <div class="projects-grid">
      {projects.map((p) => (
        <article class="project-card">
          <div class="project-card__image">
            {p.screenshot ? (
              <img src={p.screenshot} alt={p.title} class="project-card__screenshot" />
            ) : (
              <div class="project-card__icon">
                {
                  p.icon === "cart" ? (
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                      <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                    </svg>
                  ) : p.icon === "calendar" ? (
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                      <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
                      <line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                  ) : p.icon === "chip" ? (
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="4" y="4" width="16" height="16" rx="2"/>
                      <rect x="9" y="9" width="6" height="6"/>
                      <line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/>
                      <line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/>
                      <line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="15" x2="23" y2="15"/>
                      <line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="15" x2="4" y2="15"/>
                    </svg>
                  ) : p.icon === "tool" ? (
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
                    </svg>
                  ) : p.icon === "sun" ? (
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="5"/>
                      <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
                      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                      <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
                      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                    </svg>
                  ) : null
                }
              </div>
            )}
          </div>
          <div class="project-card__body">
            <h3 class="project-card__title">{p.title}</h3>
            <p class="project-card__desc">{p.description}</p>
            <div class="project-card__tech">
              {p.tech.map((t) => <span>{t}</span>)}
            </div>
            <div class="project-card__links">
              {p.links.map((l) => (
                <a
                  href={l.url}
                  target="_blank"
                  class:list={[
                    "project-card__link",
                    l.label === "Demo" && "project-card__link--demo",
                  ]}
                >
                  {l.label} ↗
                </a>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .projects-grid {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .project-card {
    display: grid;
    grid-template-columns: 280px 1fr;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .project-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow);
  }

  .project-card__image {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--bg-secondary);
    min-height: 200px;
  }

  .project-card__screenshot {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .project-card__icon {
    color: var(--text-muted);
    opacity: 0.5;
  }

  .project-card__body {
    padding: 28px;
    display: flex;
    flex-direction: column;
  }

  .project-card__title {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .project-card__desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 16px;
    flex: 1;
  }

  .project-card__tech {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 16px;
  }

  .project-card__tech span {
    font-size: 0.75rem;
    color: var(--text-muted);
    padding: 4px 10px;
    border-radius: 4px;
    background: var(--bg-secondary);
  }

  .project-card__links {
    display: flex;
    gap: 16px;
  }

  .project-card__link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .project-card__link:hover {
    color: var(--text);
  }

  .project-card__link--demo {
    color: var(--accent);
  }

  .project-card__link--demo:hover {
    color: var(--accent-hover);
  }

  @media (max-width: 740px) {
    .project-card {
      grid-template-columns: 1fr;
    }

    .project-card__image {
      min-height: 160px;
    }

    .project-card__body {
      padding: 20px;
    }
  }
</style>
