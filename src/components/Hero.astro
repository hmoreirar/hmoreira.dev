---
---

<section class="hero">
  <div class="container">
    <h1 class="hero__title">
      Nicolás Moreira
      <span class="hero__accent">.</span>
    </h1>
    <p class="hero__role">
      Frontend / Full Stack Developer
    </p>
    <p class="hero__desc">
      Desarrollo aplicaciones web modernas con React, Next.js y TypeScript.
      Especializado en dashboards, SaaS y herramientas de productividad.
    </p>
    <div class="hero__links">
      <a href="#projects" class="hero__link hero__link--primary">Proyectos</a>
      <a href="https://github.com/hmoreirar" target="_blank" class="hero__link">GitHub</a>
      <a href="https://linkedin.com/in/hmoreirar" target="_blank" class="hero__link">LinkedIn</a>
      <a href="mailto:hmoreirar@gmail.com" class="hero__link">Contacto</a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .hero__title {
    font-size: clamp(2.8rem, 7vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin-bottom: 16px;
  }

  .hero__accent {
    color: var(--accent);
  }

  .hero__role {
    font-size: 1.2rem;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 20px;
  }

  .hero__desc {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 500px;
    margin-bottom: 36px;
  }

  .hero__links {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
  }

  .hero__link {
    padding: 10px 20px;
    border-radius: var(--radius);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--text-secondary);
    transition: all 0.2s ease;
  }

  .hero__link:hover {
    color: var(--text);
    background: var(--bg-secondary);
  }

  .hero__link--primary {
    background: var(--accent);
    color: white;
  }

  .hero__link--primary:hover {
    background: var(--accent-hover);
    color: white;
  }
</style>
